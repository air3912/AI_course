APP_NAME=Knowledge Network API
APP_ENV=prod
APP_DEBUG=false

API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://your-domain.com

DATABASE_URL=sqlite:////app/data/app.db

UPLOAD_DIR=/app/data/raw_uploads
PARSED_DIR=/app/data/parsed
GRAPH_DIR=/app/data/graphs

# Frontend build-time variable
VITE_API_BASE_URL=/api/v1

# Optional LLM (OpenAI-compatible) configuration.
# Copy this file to `.env` on the server and fill in the API key there. Do not commit the real key here.
LLM_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
# Paste your actual key in the deployment `.env` file.
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1400
