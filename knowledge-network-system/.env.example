APP_NAME=Knowledge Network API
APP_ENV=dev
APP_DEBUG=true

API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173

DATABASE_URL=sqlite:///./app.db

UPLOAD_DIR=../data/raw_uploads
PARSED_DIR=../data/parsed
GRAPH_DIR=../data/graphs

# Optional LLM (OpenAI-compatible) configuration.
# Set `LLM_ENABLED=true` and provide API key/model to enable LLM-based graph extraction.
LLM_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1400
